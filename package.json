{
  "name": "cacablu",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && node scripts/inline-dist.mjs",
    "package": "npm run build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "studio:dev": "npm run dev --workspace @cacablu/studio",
    "studio:build": "npm run build --workspace @cacablu/studio",
    "timeline:build": "npm run build --workspace @cacablu/timeline"
  },
  "dependencies": {
    "dockview-core": "^5.2.0"
  },
  "devDependencies": {
    "@eslint/js": ">=9 <10",
    "eslint": ">=9 <10",
    "globals": ">=15 <16",
    "typescript-eslint": ">=8 <9",
    "typescript": ">=5 <6",
    "vite": ">=7 <8",
    "vitest": ">=3 <4"
  }
}
